{
  "info": {
    "name": "Course Management System - Session04",
    "description": "Postman collection for Session04 JPA, DTO, student enrollment, search, dropout, and error scenarios.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "instructorId",
      "value": ""
    },
    {
      "key": "courseId",
      "value": ""
    },
    {
      "key": "inactiveCourseId",
      "value": ""
    },
    {
      "key": "studentId",
      "value": ""
    },
    {
      "key": "secondStudentId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01 - Instructor And Course",
      "item": [
        {
          "name": "Create Instructor",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nguyen Van A\",\n  \"email\": \"a@example.com\"\n}"
            },
            "url": "{{baseUrl}}/instructors"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('created instructor', () => pm.expect(json.message).to.eql('Instructor created'));",
                  "pm.collectionVariables.set('instructorId', json.data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Course",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Spring Data JPA\",\n  \"status\": \"INACTIVE\",\n  \"instructorId\": {{instructorId}}\n}"
            },
            "url": "{{baseUrl}}/courses"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('created course', () => pm.expect(json.message).to.eql('Course created'));",
                  "pm.test('course uses instructor dto', () => pm.expect(json.data.instructor.id).to.eql(Number(pm.collectionVariables.get('instructorId'))));",
                  "pm.collectionVariables.set('courseId', json.data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Course Active",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Spring Data JPA\",\n  \"status\": \"ACTIVE\",\n  \"instructorId\": {{instructorId}}\n}"
            },
            "url": "{{baseUrl}}/courses/{{courseId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('course active', () => pm.expect(json.data.status).to.eql('ACTIVE'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Courses",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/courses"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('returns course dtos', () => pm.expect(json.data[0]).to.have.keys(['id', 'title', 'status', 'instructor']));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - Student Enrollment",
      "item": [
        {
          "name": "Create Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tran Thi B\",\n  \"email\": \"b@example.com\"\n}"
            },
            "url": "{{baseUrl}}/students"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('studentId', json.data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Enroll Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": {{studentId}}\n}"
            },
            "url": "{{baseUrl}}/courses/{{courseId}}/enrollments"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('enrollment created', () => pm.expect(json.message).to.eql('Enrollment created'));",
                  "pm.test('has enrolledAt', () => pm.expect(json.data.enrolledAt).to.be.a('string'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Reject Duplicate Enrollment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": {{studentId}}\n}"
            },
            "url": "{{baseUrl}}/courses/{{courseId}}/enrollments"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 400', () => pm.response.to.have.status(400));",
                  "const json = pm.response.json();",
                  "pm.test('duplicate rejected', () => pm.expect(json.message).to.eql('Student already enrolled in this course'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Search Enrolled Students",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/courses/{{courseId}}/enrollments/students?search=Tran"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('student found', () => pm.expect(json.data.length).to.be.at.least(1));"
                ]
              }
            }
          ]
        },
        {
          "name": "Drop Student",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/courses/{{courseId}}/enrollments/students/{{studentId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03 - Compatibility Endpoint",
      "item": [
        {
          "name": "Create Second Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Le Van C\",\n  \"email\": \"c@example.com\"\n}"
            },
            "url": "{{baseUrl}}/students"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('secondStudentId', json.data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Enrollment Via Students Enrollments",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": {{secondStudentId}},\n  \"courseId\": {{courseId}}\n}"
            },
            "url": "{{baseUrl}}/students-enrollments"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('compat endpoint returns same shape', () => pm.expect(json.data.courseId).to.eql(Number(pm.collectionVariables.get('courseId'))));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "04 - Error Cases",
      "item": [
        {
          "name": "Create Course With Missing Instructor",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Invalid Course\",\n  \"status\": \"ACTIVE\",\n  \"instructorId\": 999999\n}"
            },
            "url": "{{baseUrl}}/courses"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 404', () => pm.response.to.have.status(404));",
                  "const json = pm.response.json();",
                  "pm.test('missing instructor', () => pm.expect(json.message).to.eql('Instructor not found'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Inactive Course",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Inactive Course\",\n  \"status\": \"INACTIVE\",\n  \"instructorId\": {{instructorId}}\n}"
            },
            "url": "{{baseUrl}}/courses"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('inactiveCourseId', json.data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Reject Inactive Course Enrollment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": {{studentId}}\n}"
            },
            "url": "{{baseUrl}}/courses/{{inactiveCourseId}}/enrollments"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 400', () => pm.response.to.have.status(400));",
                  "const json = pm.response.json();",
                  "pm.test('inactive rejected', () => pm.expect(json.message).to.eql('Cannot enroll in an inactive course'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Missing Course",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/courses/999999"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 404', () => pm.response.to.have.status(404));",
                  "const json = pm.response.json();",
                  "pm.test('course not found', () => pm.expect(json.message).to.eql('Course not found'));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
