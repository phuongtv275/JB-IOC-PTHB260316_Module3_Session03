{
  "info": {
    "name": "Course Management System - Session05",
    "description": "Full 17-request collection matching docs/testing-scenario.md. Requests are ordered so the collection can run sequentially.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "instructorId",
      "value": ""
    },
    {
      "key": "courseId",
      "value": ""
    },
    {
      "key": "studentId",
      "value": ""
    },
    {
      "key": "inactiveCourseId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Scenario 1 - Instructor And Course Flow",
      "item": [
        {
          "name": "01 - Create Instructor",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nguyen Van A\",\n  \"email\": \"a@example.com\"\n}"
            },
            "url": "{{baseUrl}}/instructors"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('message matches', () => pm.expect(json.message).to.eql('Instructor created'));",
                  "pm.collectionVariables.set('instructorId', json.data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "02 - Create Course",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Spring Data JPA\",\n  \"status\": \"INACTIVE\",\n  \"instructorId\": {{instructorId}}\n}"
            },
            "url": "{{baseUrl}}/courses"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('created inactive course', () => pm.expect(json.data.status).to.eql('INACTIVE'));",
                  "pm.collectionVariables.set('courseId', json.data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "03 - Update Course Active",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Spring Data JPA\",\n  \"status\": \"ACTIVE\",\n  \"instructorId\": {{instructorId}}\n}"
            },
            "url": "{{baseUrl}}/courses/{{courseId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('course active', () => pm.expect(json.data.status).to.eql('ACTIVE'));"
                ]
              }
            }
          ]
        },
        {
          "name": "04 - List Courses Basic",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/courses?page=0&size=10"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('has page response', () => pm.expect(json.data).to.have.keys(['items', 'page', 'size', 'totalItems', 'totalPages', 'isLast']));",
                  "pm.test('items is array', () => pm.expect(json.data.items).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "05 - List Courses Filter Sort",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/courses?page=0&size=2&sortBy=title&direction=ASC&status=ACTIVE&keyword=Spring"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('uses projection without instructor', () => pm.expect(json.data.items[0]).to.not.have.property('instructor'));",
                  "pm.test('matches active Spring course', () => pm.expect(json.data.items.some(course => course.status === 'ACTIVE' && course.title.includes('Spring'))).to.eql(true));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Scenario 2 - Student Enrollment Flow",
      "item": [
        {
          "name": "01 - Create Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tran Thi B\",\n  \"email\": \"b@example.com\"\n}"
            },
            "url": "{{baseUrl}}/students"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('message matches', () => pm.expect(json.message).to.eql('Student created'));",
                  "pm.collectionVariables.set('studentId', json.data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "02 - Enroll Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": {{studentId}}\n}"
            },
            "url": "{{baseUrl}}/courses/{{courseId}}/enrollments"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('enrollment created', () => pm.expect(json.message).to.eql('Enrollment created'));",
                  "pm.test('has enrolledAt', () => pm.expect(json.data.enrolledAt).to.be.a('string'));"
                ]
              }
            }
          ]
        },
        {
          "name": "03 - Reject Duplicate Enrollment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": {{studentId}}\n}"
            },
            "url": "{{baseUrl}}/courses/{{courseId}}/enrollments"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 400', () => pm.response.to.have.status(400));",
                  "const json = pm.response.json();",
                  "pm.test('duplicate rejected', () => pm.expect(json.message).to.eql('Student already enrolled in this course'));"
                ]
              }
            }
          ]
        },
        {
          "name": "04 - Search Enrolled Students",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/courses/{{courseId}}/enrollments/students?search=Tran"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('returns matching student', () => pm.expect(json.data.some(student => student.name.includes('Tran'))).to.eql(true));"
                ]
              }
            }
          ]
        },
        {
          "name": "05 - Drop Student",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/courses/{{courseId}}/enrollments/students/{{studentId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Scenario 3 - Compatibility Endpoint",
      "item": [
        {
          "name": "01 - Create Enrollment Via Compatibility Endpoint",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": {{studentId}},\n  \"courseId\": {{courseId}}\n}"
            },
            "url": "{{baseUrl}}/students-enrollments"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('compat endpoint returns enrollment shape', () => pm.expect(json.data.courseId).to.eql(Number(pm.collectionVariables.get('courseId'))));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Scenario 4 - Student List Paging",
      "item": [
        {
          "name": "01 - List Students Basic",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/students?page=0&size=10"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('has page response', () => pm.expect(json.data).to.have.keys(['items', 'page', 'size', 'totalItems', 'totalPages', 'isLast']));"
                ]
              }
            }
          ]
        },
        {
          "name": "02 - List Students Filter Sort",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/students?page=0&size=2&sortBy=name&direction=ASC&keyword=Tran"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('student matches keyword', () => pm.expect(json.data.items.some(student => student.name.includes('Tran'))).to.eql(true));"
                ]
              }
            }
          ]
        },
        {
          "name": "03 - List Students Negative Page",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/students?page=-1&size=2"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('negative page falls back to zero', () => pm.expect(json.data.page).to.eql(0));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Scenario 5 - Error Cases",
      "item": [
        {
          "name": "01 - Create Course With Missing Instructor",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Invalid Course\",\n  \"status\": \"ACTIVE\",\n  \"instructorId\": 999999\n}"
            },
            "url": "{{baseUrl}}/courses"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 404', () => pm.response.to.have.status(404));",
                  "const json = pm.response.json();",
                  "pm.test('missing instructor', () => pm.expect(json.message).to.eql('Instructor not found'));"
                ]
              }
            }
          ]
        },
        {
          "name": "02 - Reject Inactive Course Enrollment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": {{studentId}}\n}"
            },
            "url": "{{baseUrl}}/courses/{{inactiveCourseId}}/enrollments"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 400', () => pm.response.to.have.status(400));",
                  "const json = pm.response.json();",
                  "pm.test('inactive course rejected', () => pm.expect(json.message).to.eql('Cannot enroll in an inactive course'));"
                ]
              }
            }
          ]
        },
        {
          "name": "03 - Get Missing Course",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/courses/999999"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 404', () => pm.response.to.have.status(404));",
                  "const json = pm.response.json();",
                  "pm.test('course not found', () => pm.expect(json.message).to.eql('Course not found'));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
